{
  "name": "infralink-backend",
  "version": "1.0.0",
  "description": "AI-powered construction hiring marketplace backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "seed": "node scripts/seedDatabase.js",
    "reset": "node scripts/resetDatabase.js",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "infralink",
    "construction",
    "hiring",
    "marketplace",
    "AI"
  ],
  "author": "InfraLink Team",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.7.1",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cloudinary": "^2.2.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.2.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "natural": "^5.0.3",
    "nodemailer": "^6.9.13",
    "razorpay": "^2.9.6",
    "redis": "^4.6.14",
    "resend": "^6.12.2",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^6.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "eslint": "^9.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup.js"
    ]
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  }
}
